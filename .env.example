# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
AUTHORIZED_CHAT_ID=your_telegram_chat_id

# AI Priority (comma-separated, left = highest priority)
# Options: claude, gemini
AI_PRIORITY=claude,gemini

# Minutes to wait before retrying the primary AI after a token limit error
PRIORITY_RETRY_DELAY_MINUTES=60

# AI CLI Executables
# Windows examples shown — adjust path separators for your OS
CLAUDE_EXE=C:\Users\you\.local\bin\claude.exe
GEMINI_EXE=C:\Users\you\AppData\Roaming\npm\gemini.cmd

# AI Working Directory (project root — where CLAUDE.md / GEMINI.md / TODO.md live)
AI_PROJECT_DIR=D:\YourProject

# ── Unreal Engine (optional) ─────────────────────────────────────────
# Required only for build / editor / blueprint features.
# Leave blank (or omit) to use AI chat mode only.
UPROJECT_PATH=D:\YourProject\YourProject.uproject
ENGINE_PATH=D:\Program Files\Epic Games\UE_5.x\Engine
