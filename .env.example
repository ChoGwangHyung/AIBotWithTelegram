# ── Telegram ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
AUTHORIZED_CHAT_ID=your_telegram_chat_id

# ── AI Priority ───────────────────────────────────────────────────────
# Comma-separated list (left = highest priority). Options: claude, gemini
AI_PRIORITY=claude,gemini

# Minutes to wait before retrying the primary AI after a token limit error (default: 60)
PRIORITY_RETRY_DELAY_MINUTES=60

# ── AI CLI Executables ────────────────────────────────────────────────
# Windows examples shown — adjust path separators for your OS
CLAUDE_EXE=C:\Users\you\.local\bin\claude.exe
GEMINI_EXE=C:\Users\you\AppData\Roaming\npm\gemini.cmd

# ── Project Directory ─────────────────────────────────────────────────
# AI working directory — where CLAUDE.md / GEMINI.md / TODO.md live
AI_PROJECT_DIR=D:\YourProject

# AI_ALLOWED_DIRS: Comma-separated list of additional directories the AI can access
# without triggering a permission prompt. Example: D:\YourOtherProject
AI_ALLOWED_DIRS=

# ── Security: Pre-flight Blocks ───────────────────────────────────────
# BLOCKED_COMMANDS: Comma-separated command patterns Claude can NEVER execute.
# Added to AI_PROJECT_DIR/.claude/settings.local.json as deny rules at startup.
# Claude will refuse these commands regardless of what the user asks.
# Example: BLOCKED_COMMANDS=rm -rf,del /f /s /q,DROP TABLE,format
BLOCKED_COMMANDS=

# CONFIRM_COMMANDS: Comma-separated keywords that require Telegram y/n approval
# BEFORE the request is forwarded to the AI. The AI only runs after explicit "y".
# Example: CONFIRM_COMMANDS=git push,npm publish,git reset --hard
CONFIRM_COMMANDS=

# Minutes to wait for y/n approval before auto-cancelling (default: 3)
CONFIRM_TIMEOUT_MINUTES=3

# ── Security: Runtime Permission System ───────────────────────────────
# Smart permission policy (always active when .claude/hooks/permission-handler.js exists):
#   - Files inside AI_PROJECT_DIR       → auto-allowed (read / write / edit)
#   - Files OUTSIDE AI_PROJECT_DIR      → Telegram 1/2/3 permission prompt
#   - Delete commands (rm, del, rmdir…) → Telegram 1/2/3 permission prompt
#
# PERMISSION_REQUIRED_TOOLS: Additional tools to ALWAYS prompt, regardless of path.
# Example: PERMISSION_REQUIRED_TOOLS=WebFetch,Bash
PERMISSION_REQUIRED_TOOLS=

# Port for the internal permission HTTP server used by the hook script (default: 8099)
PERMISSION_PORT=8099

# ── Unreal Engine (optional) ─────────────────────────────────────────
# Required only for build / editor / blueprint features.
# Leave blank (or omit) to use AI chat mode only.
UPROJECT_PATH=D:\YourProject\YourProject.uproject
ENGINE_PATH=D:\Program Files\Epic Games\UE_5.x\Engine
